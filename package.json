{
  "name": "warden",
  "version": "0.1.9",
  "description": "Yatfa Warden — dashboard for AI agent chats",
  "type": "module",
  "bin": {
    "warden": "src/cli.js"
  },
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node scripts/start.mjs",
    "build": "npm --prefix web run build",
    "dev": "node src/cli.js dev",
    "ui": "node src/cli.js ui",
    "scan": "node src/cli.js scan",
    "electron": "electron .",
    "electron:dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "postinstall": "",
    "test": "node --test src",
    "dev:server": "node scripts/dev.mjs server",
    "dev:git": "node scripts/dev.mjs git",
    "dev:build": "node scripts/dev.mjs build",
    "dev:test": "node scripts/dev.mjs test"
  },
  "dependencies": {
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "io.yatfa.warden",
    "productName": "Yatfa Warden",
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "web/dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png",
      "artifactName": "yatfa-warden-setup-${version}.${ext}"
    },
    "mac": {
      "target": ["dmg"],
      "artifactName": "yatfa-warden-${version}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "artifactName": "yatfa-warden-${version}.${ext}"
    }
  }
}
